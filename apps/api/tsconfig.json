{
  "extends": "@srms/typescript-config/node.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@/*": ["./src/*"]
    },
    "noImplicitAny": true,
    "noEmit": true,
    "removeComments": true,
    "preserveConstEnums": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "sourceMap": true
  },

  "include": ["./src/**/*"],
  "exclude": ["node_modules", "**/*.spec.ts"]
}
