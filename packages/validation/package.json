{
  "name": "@srms/validation",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "files": [
    "src"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./http": {
      "types": "./src/http/index.ts",
      "import": "./src/http/index.ts"
    },
    "./health": {
      "types": "./src/health/health.schema.ts",
      "import": "./src/health/health.schema.ts"
    }
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@srms/typescript-config": "workspace:*",
    "typescript": "5.9.2"
  }
}
