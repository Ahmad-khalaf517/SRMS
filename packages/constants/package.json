{
  "name": "@srms/constants",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./order-status": {
      "types": "./src/order-status.ts",
      "import": "./dist/order-status.js"
    },
    "./order-type": {
      "types": "./src/order-type.ts",
      "import": "./dist/order-type.js"
    },
    "./payment-method": {
      "types": "./src/payment-method.ts",
      "import": "./dist/payment-method.js"
    },
    "./payment-status": {
      "types": "./src/payment-status.ts",
      "import": "./dist/payment-status.js"
    },
    "./user-role": {
      "types": "./src/user-role.ts",
      "import": "./dist/user-role.js"
    }
  },
  "devDependencies": {
    "@srms/typescript-config": "workspace:*",
    "typescript": "5.9.2"
  }
}
