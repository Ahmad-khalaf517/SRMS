{
  "name": "@srms/types",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "files": [
    "src"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./orders/order-status": {
      "types": "./src/orders/order-status.ts",
      "import": "./src/orders/order-status.ts"
    },
    "./orders/order-type": {
      "types": "./src/orders/order-type.ts",
      "import": "./src/orders/order-type.ts"
    },
    "./payments/payment-method": {
      "types": "./src/payments/payment-method.ts",
      "import": "./src/payments/payment-method.ts"
    },
    "./payments/payment-status": {
      "types": "./src/payments/payment-status.ts",
      "import": "./src/payments/payment-status.ts"
    },
    "./users/user-role": {
      "types": "./src/users/user-role.ts",
      "import": "./src/users/user-role.ts"
    },
    "./health": {
      "types": "./src/health/health.ts",
      "import": "./src/health/health.ts"
    }
  },
  "devDependencies": {
    "@srms/typescript-config": "workspace:*",
    "typescript": "5.9.2"
  }
}
